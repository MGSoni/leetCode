import java.util.*;

class Solution {
    public int longestFrequencyBalanced(int[] nums) {
        int n = nums.length;
        int best = 1;

        for (int i = 0; i < n; i++) {
            Map<Integer, Integer> freq = new HashMap<>();       // value -> frequency
            Map<Integer, Integer> freqOfFreq = new HashMap<>(); // frequency -> count of values having it

            for (int j = i; j < n; j++) {
                int x = nums[j];
                int old = freq.getOrDefault(x, 0);
                int updated = old + 1;

                if (old > 0) {
                    int c = freqOfFreq.get(old);
                    if (c == 1) freqOfFreq.remove(old);
                    else freqOfFreq.put(old, c - 1);
                }

                freq.put(x, updated);
                freqOfFreq.put(updated, freqOfFreq.getOrDefault(updated, 0) + 1);

                int length = j - i + 1;

                if (freq.size() == 1) {
                    best = Math.max(best, length);
                } else if (freqOfFreq.size() == 2) {
                    Iterator<Integer> it = freqOfFreq.keySet().iterator();
                    int a = it.next();
                    int b = it.next();
                    if (a > b) { int t = a; a = b; b = t; }
                    if (b == 2 * a) {
                        best = Math.max(best, length);
                    }
                }
            }
        }

        return best;
    }
}
