class Solution {
    public int getLength(int[] nums) {
        int n = nums.length;
        int best = 1;
        for(int i=0;i<n; i++){
            Map<Integer, Integer> freqMap = new HashMap<>();
            Map<Integer, Integer> freqOfFreq = new HashMap<>();

            for(int j=i;j<n;j++){
                int x = nums[j];
                int oldFreq = freqMap.getOrDefault(x,0);
                int updatedFreq = oldFreq+1;

                if(oldFreq > 0){
                    int freqOfOldFreq = freqOfFreq.get(oldFreq);
                    if(freqOfOldFreq == 1) freqOfFreq.remove(oldFreq);
                    else freqOfFreq.put(oldFreq, freqOfOldFreq -1);
                }

                freqMap.put(x,updatedFreq);
                freqOfFreq.put(updatedFreq, freqOfFreq.getOrDefault(updatedFreq,0)+1);

                int length = j-i+1;
                if(freqMap.size()==1){
                    best = Math.max(best, length);
                }else if(freqOfFreq.size()==2){
                    Iterator<Integer> it = freqOfFreq.keySet().iterator();
                    int a = it.next();
                    int b = it.next();
                    if(a>b){
                        int t = a;
                        a = b;
                        b = t;
                    }
                    if(b==2*a){
                        best = Math.max(best,length);
                    }
                }
            }
        }
         return best;
    }
}
